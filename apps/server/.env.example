# DMPG UML Server
# Diese Datei nach ".env" kopieren und Werte anpassen.

# HTTP-Port fuer den Express-Server
PORT=3001

# Bind-Host fuer den Express-Server (sicherer Default: localhost only)
SERVER_HOST=127.0.0.1

# Kommagetrennte Liste erlaubter Browser-Origin(s) fuer CORS
# Beispiel: http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optionales JSON-Body-Limit fuer HTTP-Requests (z.B. Vision-Uploads)
AI_HTTP_JSON_LIMIT=50mb

# Standard-Scanpfad, wenn kein Projekt aktiv ausgewaehlt wurde
# Beispiel (Windows): C:\dev\dmpg_models\data_pipeline
SCAN_PROJECT_PATH=

# Optional: Speicherort fuer persistierte Graph-/AI-Daten
# Default im Code: <apps/server>/.dmpg-data
DMPG_DATA_DIR=

# ==================================================
# Hybrid Class Diagram Scan (optional)
# ==================================================
# auto/on/off. Pyreverse wird als deterministische UML-Quelle genutzt, falls
# pylint/pyreverse in der Python-Umgebung installiert ist.
PYREVERSE_ENABLED=auto

# auto/on/off. Embeddings werden pro Projekt unter .dmpg-data/projects/<hash>
# gecached und fuer Klassendiagramm-Kontext genutzt. Ohne eigene URL nutzt
# das Embedding standardmaessig den lokalen Ollama-Endpunkt, auch wenn der
# Chat-Provider auf cloud steht.
UML_EMBEDDINGS_ENABLED=auto
UML_EMBEDDING_MODEL=embeddinggemma
UML_EMBEDDING_BASE_URL=
UML_EMBEDDING_API_KEY=
# Lokale CPU-Embeddings brauchen oft mehr Zeit beim ersten Modell-Load.
UML_EMBEDDING_TIMEOUT_MS=120000
# embeddinggemma hat lokal typischerweise 2048 Kontext; kleine Chunks verhindern
# "input length exceeds the context length" und halten CPU-Scans beherrschbar.
UML_EMBEDDING_BATCH_SIZE=1
UML_EMBEDDING_CHUNK_CHARS=1200
UML_EMBEDDING_CHUNK_OVERLAP=120
UML_EMBEDDING_MAX_CHUNKS=250
UML_EMBEDDING_KEEP_ALIVE=10m

# Begrenzung der LLM-Klassendiagramm-Batches pro Scan.
UML_CLASS_DIAGRAM_LLM_MAX_VIEWS=12

# AI-Provider: "cloud" oder "local"
AI_PROVIDER=cloud

# Globales Cloud-/Fallback-Modell (wird nur bei AI_PROVIDER=cloud genutzt)
OLLAMA_MODEL=llama3.1:8b

# Cloud-Endpunkt (wird bei AI_PROVIDER=cloud genutzt)
OLLAMA_BASE_URL=https://ollama.com

# API-Key fuer Cloud-Betrieb (Bearer Token), bei local ignoriert
OLLAMA_API_KEY=

# Optionales Cloud-spezifisches Modell (ueberschreibt OLLAMA_MODEL in cloud)
OLLAMA_CLOUD_MODEL=

# Lokaler Ollama-Endpunkt (wird bei AI_PROVIDER=local und standardmaessig fuer Embeddings genutzt)
OLLAMA_LOCAL_URL=http://127.0.0.1:11434

# Das lokale Modell wird im AI Workspace ueber die laufenden `ollama ps`-Modelle gewaehlt.
# Optional kann fuer Legacy-Setups weiterhin OLLAMA_LOCAL_MODEL in einer eigenen .env gesetzt werden.
OLLAMA_LOCAL_MODEL=

# ==================================================
# AI Model Routing
# ==================================================
# false = alles nutzt weiterhin das globale Standardmodell oben
# true  = Tasks nutzen die spezialisierten Modelle unten mit Fallback-Kette
AI_MODEL_ROUTING_ENABLED=false

# Optionales Default-Modell fuer unspezifische/general Tasks
AI_DEFAULT_TASK_MODEL=

# Allgemeines Fallback fuer Tasks ohne eigenes Modell
# Beispielwert - bitte fuer die eigene Umgebung anpassen
UML_FALLBACK_MODEL=qwen3.5:cloud

# Spezialisierte Modelle je AI-Task
# Beispielwerte - bitte fuer die eigene Umgebung anpassen

# Code-Strukturanalyse, Signaturen, Parameter, Returns, Calls, Imports, Vererbungen
UML_CODE_ANALYSIS_MODEL=qwen3-coder:480b-cloud

# UML-Qualitaet, Layering, Gruppen-/Package-Review, Lesbarkeit
UML_DIAGRAM_REVIEW_MODEL=qwen3.5:cloud

# Bild-/Screenshot-/Draw.io-/Diagramm-Pruefung
# Muss auf ein vision-faehiges / multimodales Modell zeigen
UML_VISION_REVIEW_MODEL=qwen3.5:cloud

# Labels, Titel, Benennungen, UML-Notizen, kurze Beschreibungen
UML_LABELING_MODEL=qwen3.5:cloud

# Plausibilitaetspruefung fuer vorgeschlagene Relationen
UML_RELATION_VALIDATION_MODEL=glm-5

# ==================================================
# Process Overview (optional)
# ==================================================
# "manual" = process-diagram.json bevorzugen, sonst auto aus Graph
DMPG_PROCESS_OVERVIEW_MODE=

# "1" = bei Auto-Fehler auf process-diagram.json zurueckfallen
DMPG_PROCESS_OVERVIEW_DEBUG_JSON=
